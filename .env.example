# =============================
# Runtime
# =============================
DRY_RUN=true
SCAN_INTERVAL_SECONDS=600
EDGE_THRESHOLD=0.15
TAKE_PROFIT_DELTA=0.10
STOP_LOSS_MULTIPLIER=0.85
MAX_ORDER_USDC=50
MAX_TOTAL_EXPOSURE_USDC=300
KELLY_FRACTION=0.25
# 精确市场 URL（单个或逗号分隔多个 /event/ URL，也接受 slug）
TARGET_MARKET_URLS=
# 话题页 URL（如 polymarket.com/iran/trump-iran，会拉取整个话题下所有活跃市场）
TARGET_TOPIC_URLS=

# =============================
# OpenRouter / LLM
# =============================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_1=openai/gpt-4o-mini
MODEL_2=anthropic/claude-3.5-sonnet
MODEL_3=google/gemini-2.0-flash-001
MODEL_1_WEIGHT=0.34
MODEL_2_WEIGHT=0.33
MODEL_3_WEIGHT=0.33

# =============================
# Data APIs
# =============================
NEWS_API_KEY=
TAVILY_API_KEY=
X_BEARER_TOKEN=

# =============================
# Polymarket / CLOB
# =============================
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
# 0=EOA, 1=POLY_PROXY, 2=POLY_GNOSIS_SAFE（网页账户填 2）
POLYMARKET_SIGNATURE_TYPE=2

# =============================
# IM 消息通知（可选）
# =============================
# 飞书:  https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# 企业微信: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# 钉钉:  https://oapi.dingtalk.com/robot/send?access_token=xxx
# Discord: https://discord.com/api/webhooks/xxx/xxx
IM_WEBHOOK_URL=
